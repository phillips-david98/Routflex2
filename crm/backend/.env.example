# Copie para .env e ajuste conforme o ambiente.

# Porta do servidor Express
# Dev local: 3001 | Produção: geralmente definida pelo orquestrador (Railway, Heroku…)
PORT=3001

# Banco de dados PostgreSQL (deixe em branco para usar Mock in-memory)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/routflex_crm

# URL do backend de roteirização Python (FastAPI)
# Dev local:   http://localhost:8000
# Produção:    https://routing-api.routflex.com
ROTEIRIZACAO_API_URL=http://localhost:8000

# Timeout para chamadas ao backend de roteirização (ms)
ROTEIRIZACAO_TIMEOUT_MS=30000

# Modo Mock: 'true' usa dados in-memory (padrão). 'false' requer DATABASE_URL.
USE_MOCK=false

# Origens permitidas no CORS (lista separada por vírgulas)
# Dev local:   http://localhost:5173,http://127.0.0.1:5173
# Produção:    https://crm.routflex.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:3001,http://localhost:3001

NODE_ENV=development
